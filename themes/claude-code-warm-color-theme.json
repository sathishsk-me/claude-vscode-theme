  "semanticTokenColors": {
    "class": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "class.defaultLibrary": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "enum": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "enumMember": {
      "foreground": "#5DE4FA"
    },
    "function": {
      "foreground": "#FFA65D",
      "fontStyle": "italic"
    },
    "function.defaultLibrary": {
      "foreground": "#FFA65D",
      "fontStyle": "italic"
    },
    "method": {
      "foreground": "#FFA65D",
      "fontStyle": "italic"
    },
    "interface": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "keyword": {
      "foreground": "#C79BFF",
      "fontStyle": "bold"
    },
    "macro": {
      "foreground": "#FF85C8"
    },
    "namespace": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "parameter": {
      "foreground": "#E07A47"
    },
    "property": {
      "foreground": "#9C9893"
    },
    "property.readonly": {
      "foreground": "#9C9893"
    },
    "string": {
      "foreground": "#86E89A"
    },
    "type": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "type.defaultLibrary": {
      "foreground": "#7AB8FF",
      "fontStyle": "italic"
    },
    "typeParameter": {
      "foreground": "#FFDF61",
      "fontStyle": "italic"
    },
    "variable": {
      "foreground": "#E4E4E4"
    },
    "variable.readonly": {
      "foreground": "#FFDF61"
    },
    "variable.defaultLibrary": {
      "foreground": "#C79BFF",
      "fontStyle": "italic"
    },
    "comment": {
      "foreground": "#969696",
      "fontStyle": "italic"
    },
    "decorator": {
      "foreground": "#FF85C8",
      "fontStyle": "italic"
    },
    "operator": {
      "foreground": "#5DE4FA"
    },
    "regexp": {
      "foreground": "#FF85C8"
    },
    "number": {
      "foreground": "#FFDF61"
    },
    "boolean": {
      "foreground": "#FFDF61"
    },
    "event": {
      "foreground": "#FFA65D"
    },
    "*.async": {
      "fontStyle": "italic"
    },
    "*.modification": {
      "fontStyle": "italic"
    },
    "*.declaration": {
      "fontStyle": ""
    },
    "*.readonly": {
      "fontStyle": ""
    },
    "*.static": {
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "*.abstract": {
      "fontStyle": "italic"
    }
  },
  "tokenColors": [
    {
      "name": "Basic text & variable names",
      "scope": [
        "text",
        "source",
        "variable.other.readwrite",
        "punctuation.definition.variable"
      ],
      "settings": {
        "foreground": "#E4E4E4"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#969696",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#86E89A"
      }
    },
    {
      "name": "String escapes",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#FF85C8"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "variable.other.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#FFDF61"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.word",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "variable.language.super",
        "punctuation.definition.keyword"
      ],
      "settings": {
        "foreground": "#C79BFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#5DE4FA"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FFA65D"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#7AB8FF"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.interface",
        "entity.name.trait"
      ],
      "settings": {
        "foreground": "#7AB8FF"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.enum"
      ],
      "settings": {
        "foreground": "#7AB8FF"
      }
    },
    {
      "name": "Enum members",
      "scope": [
        "variable.other.enummember",
        "constant.other.enum"
      ],
      "settings": {
        "foreground": "#5DE4FA"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#E07A47"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "entity.name.tag.yaml",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#9C9893"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "meta.annotation",
        "punctuation.decorator",
        "punctuation.definition.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#FF85C8"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "constant.character.character-class.regexp",
        "constant.other.character-class.regexp",
        "constant.other.character-class.set.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#FF85C8"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF7A7A"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute"
      ],
      "settings": {
        "foreground": "#FFA65D"
      }
    },
    {
      "name": "Support",
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#FFDF61"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#7AB8FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFA65D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#FFA65D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup code",
      "scope": [
        "markup.inline.raw",
        "markup.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#86E89A"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7AB8FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup lists",
      "scope": [
        "markup.list",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#FF7A7A"
      }
    },
    {
      "name": "Markup quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9C9893"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly",
        "punctuation.section",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments"
      ],
      "settings": {
        "foreground": "#7A7A7A"
      }
    },
    {
      "name": "Storage modifiers",
      "scope": [
        "storage.modifier.async",
        "storage.modifier.const",
        "storage.modifier.static",
        "storage.modifier.readonly"
      ],
      "settings": {
        "foreground": "#C79BFF"
      }
    },
    {
      "name": "Special variables",
      "scope": [
        "variable.language",
        "variable.other.predefined"
      ],
      "settings": {
        "foreground": "#C79BFF"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#86E89A"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#FF7A7A"
      }
